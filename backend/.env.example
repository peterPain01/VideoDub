# ── VideoDub Backend Configuration ──

# TTS Provider: "edge" (free default, neural), "google" (free fallback), "elevenlabs" (premium), "local" (your model)
TTS_PROVIDER=edge

# ── ElevenLabs (only needed if TTS_PROVIDER=elevenlabs) ──
ELEVENLABS_API_KEY=your_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# ── Local Model (only needed if TTS_PROVIDER=local) ──
LOCAL_MODEL_PATH=
LOCAL_SERVER_URL=http://localhost:5555

# ── Edge TTS (only needed if TTS_PROVIDER=edge) ──
EDGE_TTS_VOICE=vi-VN-HoaiMyNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz

# ── Cache ──
TTS_CACHE_MAX_SIZE=500
